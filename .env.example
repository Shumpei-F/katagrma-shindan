# ===== 必須 =====
# Anthropic API キー（https://console.anthropic.com/ で取得）
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# サーバーポート
PORT=3000

# ===== オプショナル =====
# 管理画面 /admin のパスワード（未設定なら /admin は無効化）
# ユーザー名は任意、パスワードのみチェック
ADMIN_PASSWORD=

# Zoho CRM Webhook URL（未設定ならZoho連携はno-op）
# Zoho Flow / Zoho CRM の Webhook カスタムファンクションで受け口を作成する
ZOHO_WEBHOOK_URL=

# Resend API キー（未設定ならメール送信はno-op）
# https://resend.com/ で取得
RESEND_API_KEY=

# 送信元メールアドレス（Resend で認証済みドメインを使用）
FROM_EMAIL=diagnosis@katagrma.jp

# 営業チーム通知先メールアドレス（未設定なら相談申込通知は送られない）
SALES_EMAIL=
